const changeMinuteFormat = (min) => {
  const days = Math.floor(min / (24 * 60));
  const hours = Math.floor((min % (24 * 60)) / 60);
  const minutes = min % 60;

  let result = "";

  if (days > 0) result += `${days} day${days > 1 ? "s" : ""} `;
  if (days > 0 || hours > 0) result += `${hours} hr${hours > 1 ? "s" : ""} `;
  if (days > 0 || hours > 0 || minutes > 0 || result === "")
    result += `${minutes} min`;

  return result.trim();
};

export default changeMinuteFormat;
